# HUAWEI Health Kit API Credentials
# Copy this file to .env and fill in your credentials
# Register app at: https://developer.huawei.com/consumer/en/

# Developer / Project info (reference only)
# Developer ID : your_developer_id
# Project ID   : your_project_id

# OAuth2 Client Credentials (from AppGallery Connect → AppHealth → Project settings)
HUAWEI_CLIENT_ID=your_app_id
HUAWEI_CLIENT_SECRET=your_app_secret

# OAuth2 Access Token (obtained after user authorization via Authorization Code Flow)
HUAWEI_ACCESS_TOKEN=your_access_token

# API Region: CN (China), EU (Europe), AS (Asia-Pacific), RU (Russia)
# ตรวจสอบที่ AppGallery Connect → Account settings → Account region
HUAWEI_API_REGION=CN

# ============================================================
# Google Fit API Credentials
# สร้าง OAuth2 Client ID ที่: https://console.cloud.google.com/apis/credentials
# Application type: Desktop app
# ============================================================
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
